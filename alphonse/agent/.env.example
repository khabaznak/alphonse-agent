# Path to the nervous system SQLite database.
# Relative paths are resolved from alphonse/agent/.
NERVE_DB_PATH=agent/nervous_system/db/nerve-db

# In this pipeline, every action emits an internal outcome signal (action.succeeded or action.failed). 
# That outcome can trigger another transition, which can run another action, and so on.
# MAX_TRANSITION_DEPTH limits how many of those chained outcome emissions are allowed for one flow.
MAX_TRANSITION_DEPTH=5

# Local LLM model + timeout for runners.
ALPHONSE_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=mistral:7b-instruct
LOCAL_LLM_TIMEOUT_SECONDS=240
OLLAMA_BASE_URL=http://localhost:11434
ALPHONSE_GRAPH_RECURSION_LIMIT=100
ALPHONSE_VISION_MODEL=qwen3-vl:4b
ALPHONSE_VISION_TIMEOUT_SECONDS=60
# PDCA queue slicing is enabled by default. Set to "false" only for maintenance/testing.
# When disabled, conscious ingress is fail-fast (no enqueue) and users receive a deterministic unavailable reply.
ALPHONSE_PDCA_SLICING_ENABLED=true
ALPHONSE_PDCA_QUEUE_POLL_SECONDS=5
ALPHONSE_PDCA_QUEUE_LEASE_SECONDS=30
ALPHONSE_PDCA_QUEUE_DISPATCH_COOLDOWN_SECONDS=30
ALPHONSE_PDCA_QUEUE_INTERACTIVE_BOOST=40
ALPHONSE_PDCA_QUEUE_STARVATION_WARN_SECONDS=300
ALPHONSE_PDCA_QUEUE_STARVATION_WARN_COOLDOWN_SECONDS=60
ALPHONSE_PDCA_QUEUE_WORKER_ID=pdca-queue-runner
# Event-driven PDCA dispatch watchdog (recovery scanner cadence in seconds)
ALPHONSE_PDCA_DISPATCH_WATCHDOG_SECONDS=30

# OpenCode provider (ALPHONSE_LLM_PROVIDER=opencode)
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_MODEL=ollama/mistral:7b-instruct
OPENCODE_TIMEOUT_SECONDS=120
OPENCODE_API_KEY=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=

# LlamaFarm provider (ALPHONSE_LLM_PROVIDER=llamafarm)
LLAMAFARM_BASE_URL=http://127.0.0.1:8002/v1
LLAMAFARM_MODEL=mistral:7b-instruct
LLAMAFARM_TIMEOUT_SECONDS=120
LLAMAFARM_API_KEY=

# Alphonse API (in-process)
ALPHONSE_ENABLE_API=true
ALPHONSE_API_HOST=0.0.0.0
ALPHONSE_API_PORT=8001
ALPHONSE_API_TOKEN=

# Relay transport (Supabase)
RELAY_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ALPHONSE_ID=alphonse-local
RELAY_HEARTBEAT_SECS=15
RELAY_COALESCE_MS=500
RELAY_JWT_SECRET=
RELAY_TOKEN_TTL_SECS=604800
RELAY_BASE_URL=
HOME_ID=
PAIRING_TOKEN_TTL_DAYS=30
PAIRING_TTL_MINUTES=5

# Telegram integration
ALPHONSE_ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLL_INTERVAL_SEC=1.0

# Integration sandbox root override.
# Default behavior prefers workdir sandbox root (main/sandboxes, then dumpster/sandboxes) when available.
ALPHONSE_SANDBOX_ROOT=

# CLI extremity
ALPHONSE_ENABLE_CLI=false

# Timed signals
TIMED_SIGNAL_DISPATCH_WINDOW_SECONDS=1800
TIMED_SIGNAL_IDLE_SLEEP_SECONDS=60

# Reminder rendering
ALPHONSE_DEFAULT_LOCALE=es-MX
ALPHONSE_TONE=friendly
ALPHONSE_ADDRESS_STYLE=tu

# Local TTS backend selection
# - say: macOS native `say` command
# - qwen: Qwen3-TTS Python backend (requires qwen-tts + soundfile)
# Operational policy: keep `say` as emergency fallback; use `qwen` as primary once stable.
ALPHONSE_TTS_BACKEND=say
ALPHONSE_QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
ALPHONSE_QWEN_TTS_DEVICE_MAP=auto
# optional: bfloat16 | float16 | float32
ALPHONSE_QWEN_TTS_DTYPE=
ALPHONSE_QWEN_TTS_SPEAKER=Ryan
# Optional style/instruction for Qwen synthesis
ALPHONSE_QWEN_TTS_INSTRUCT=
# Auto by default, can be forced (for example: es-MX, en-US, Auto)
ALPHONSE_QWEN_TTS_LANGUAGE=Auto

# Tier presets for macOS arm64 tuning ladder:
# HQ-Stable
# ALPHONSE_QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
# ALPHONSE_QWEN_TTS_DEVICE_MAP=cpu
# ALPHONSE_QWEN_TTS_DTYPE=float32
#
# HQ-Balanced (target)
# ALPHONSE_QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# ALPHONSE_QWEN_TTS_DEVICE_MAP=auto
# ALPHONSE_QWEN_TTS_DTYPE=float16
#
# HQ-Strict
# (same as HQ-Balanced + ALPHONSE_QWEN_TTS_INSTRUCT with fixed speaker)

# Timer sense
TIMER_POLL_SECONDS=60

# Observability (separate logs DB)
ALPHONSE_OBSERVABILITY_DB_PATH=agent/nervous_system/db/observability.db
ALPHONSE_OBSERVABILITY_MAX_ROWS=1000000
ALPHONSE_OBSERVABILITY_NON_ERROR_TTL_DAYS=14
ALPHONSE_OBSERVABILITY_ERROR_TTL_DAYS=30
ALPHONSE_OBSERVABILITY_MAINTENANCE_SECONDS=21600

# Global execution mode for terminal-like capabilities: readonly | dev | ops
ALPHONSE_EXECUTION_MODE=readonly
ALPHONSE_TERMINAL_DEFAULT_TIMEOUT_SECONDS=120
ALPHONSE_TERMINAL_MAX_TIMEOUT_SECONDS=1800

# Jobs storage root (optional).
# If unset, defaults to sandbox alias "main"/jobs (fallback: dumpster), else data/jobs.
ALPHONSE_JOBS_ROOT=

# SSH terminal tool (disabled by default)
ALPHONSE_ENABLE_SSH_TERMINAL=false
ALPHONSE_SSH_TERMINAL_DEFAULT_TIMEOUT_SECONDS=30
ALPHONSE_SSH_TERMINAL_MAX_TIMEOUT_SECONDS=600
ALPHONSE_SSH_TERMINAL_CONNECT_TIMEOUT_SECONDS=10
ALPHONSE_SSH_TERMINAL_ALLOW_AGENT=true
ALPHONSE_SSH_TERMINAL_LOOK_FOR_KEYS=true
ALPHONSE_SSH_TERMINAL_STRICT_HOST_KEY=false
ALPHONSE_SSH_TERMINAL_KNOWN_HOSTS_PATH=
